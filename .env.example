# ============================================
# HINTO - ENVIRONMENT CONFIG
# ============================================
# Rename this file to .env before running
# ============================================

# ============================================
# ENVIRONMENT MODE (REQUIRED) (paper/testnet/live)
# ============================================
# paper:   Simulated execution, uses real market data (Safe)
# testnet: Binance Futures Testnet (Fake Money, Real Server)
# live:    Binance Futures Production (Real Money)
ENV=paper

# ============================================
# BINANCE PRODUCTION (Real Money) - ENV=live
# ============================================
BINANCE_API_KEY=your_production_api_key_here
BINANCE_API_SECRET=your_production_secret_key_here

# ============================================
# BINANCE TESTNET (Demo) - ENV=testnet
# ============================================
BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_secret_key_here

# ============================================
# STRATEGY CONFIGURATION (Shark Tank / Limit Sniper)
# ============================================
STRATEGY_STRICT_MODE=false
STRATEGY_REGIME_FILTER_MODE=penalty
STRATEGY_BB_THRESHOLD_PCT=0.025
STRATEGY_VWAP_THRESHOLD_PCT=0.020
STRATEGY_ADX_THRESHOLD=20.0
STRATEGY_MIN_CONFLUENCE_SCORE=0.60
STRATEGY_COOLDOWN_SECONDS=300
STRATEGY_ALLOW_FLIP=true

# ============================================
# PORTFOLIO SYMBOLS (Shark Tank Mode)
# ============================================
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,TAOUSDT,FETUSDT,ONDOUSDT,XRPUSDT,DOGEUSDT,ADAUSDT

# ============================================
# TELEGRAM NOTIFICATION
# ============================================
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# RISK GUARDIAN (sidecar)
# ============================================
RG_DRY_RUN=true
RG_GROQ_API_KEY=
RG_FINNHUB_API_KEY=
RG_TRADER_BASE_URL=http://backend:8000
