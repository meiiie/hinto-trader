{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hinto",
  "version": "0.2.1",
  "identifier": "io.hinto.trader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hinto",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "splashscreen",
        "title": "Hinto",
        "url": "splash.html",
        "width": 800,
        "height": 500,
        "resizable": false,
        "decorations": false,
        "center": true,
        "alwaysOnTop": true,
        "focus": true,
        "visible": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright (c) 2026 Hinto contributors",
    "shortDescription": "Hinto - Local-first crypto futures trading engine",
    "longDescription": "Research-grade crypto futures trading engine with backtesting, paper mode, and local-first execution.",
    "license": "LICENSE.txt",
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English",
          "Vietnamese"
        ],
        "customLanguageFiles": {
          "Vietnamese": "lang/Vietnamese.nsh"
        },
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/header.bmp",
        "sidebarImage": "icons/sidebar.bmp"
      }
    }
  }
}
