# Frontend environment template
# Copy to .env.local or .env.production locally; never commit real endpoints/secrets.

VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Optional: dynamic IP unlock Lambda.
# Values in VITE_* are bundled into the client and are public.
VITE_LAMBDA_UNLOCK_URL=
VITE_LAMBDA_SECRET_KEY=
