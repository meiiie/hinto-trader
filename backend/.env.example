# Binance API Configuration
# Copy this file to .env and fill in your credentials

# API Keys (Get from: https://www.binance.com/en/my/settings/api-management)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Trading Mode: true = Testnet, false = Live
BINANCE_USE_TESTNET=true

# Symbols to trade (comma-separated)
SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT

# Trading parameters
TRADING_MODE=TESTNET

# ============================================
# BACKTEST SYMBOL CONFIGURATION
# ============================================
# USE_FIXED_SYMBOLS: Controls how symbols are selected for backtest
#   - false (default): Load top N symbols at backtest START DATE (dynamic, prevents look-ahead bias)
#   - true: Load from BACKTEST_SYMBOLS list below (fixed, for testing specific symbols)
USE_FIXED_SYMBOLS=false

# BACKTEST_SYMBOLS: Fixed symbol list for backtest (only used if USE_FIXED_SYMBOLS=true)
# Example: Top 10 symbols you want to test consistently across different time periods
# This avoids look-ahead bias by using a predetermined list instead of current top symbols
BACKTEST_SYMBOLS=ETHUSDT,BTCUSDT,SOLUSDT,XRPUSDT,BNBUSDT,ADAUSDT,LINKUSDT,AVAXUSDT,LTCUSDT,DOGEUSDT

# ============================================
# BACKTEST CSV TIMEZONE CONFIGURATION
# ============================================
# BACKTEST_TIMEZONE_OFFSET: Timezone offset in hours for CSV timestamp display
# Default: 7 (Vietnam time, UTC+7)
# Examples:
#   - 0: UTC
#   - 7: Vietnam (UTC+7)
#   - 8: Singapore/China (UTC+8)
#   - -5: US Eastern (UTC-5)
BACKTEST_TIMEZONE_OFFSET=7
